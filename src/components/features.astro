---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "16\" Cup Races",
    description:
      "Mini-bikes, major stakes. We host quarterly cup series (Spring, Summer, Fall, Winter) at local dirt tracks and trail centers.",
    icon: "bx:bxs-flag-alt",
  },
  {
    title: "Limited Apparel Drops",
    description:
      "Custom jersey designs, tees, and caps designed by and for small-wheel riders, featuring seamless Stripe integrations.",
    icon: "bx:bxs-shopping-bag",
  },
  {
    title: "Interactive Webart",
    description:
      "Explore decentralized 3D canvases, digital galleries, and interactive artboards parsed directly from Artformatics.",
    icon: "bx:bxs-cube-alt",
  },
  {
    title: "Live Google Calendar",
    description:
      "Never miss a gate drop. Dynamic calendar integration ensures all race schedules, trail locations, and times stay perfectly up-to-date.",
    icon: "bx:bxs-calendar",
  },
  {
    title: "J-Edit Community Feed",
    description:
      "Check out custom bike builds, parts upgrades, community race edits, and lifestyle captures submitted directly by our riders.",
    icon: "bx:bxs-video",
  },
  {
    title: "Open To Everyone",
    description:
      "Zero elitism, pure fun. If you love spinning tiny wheels, laughing with friends, and sharing good vibes, you belong on the grid.",
    icon: "bx:bxs-smile",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Why Join the Spice Co. Grid?
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    We build custom small-wheel setups, race tiny bikes, release limited apparel, and showcase interactive digital artboards. Here's what we are all about.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full p-2 w-8 h-8 shrink-0 flex items-center justify-center">
          <Icon class="text-white w-4 h-4" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed text-sm">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
