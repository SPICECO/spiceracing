---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import { fetchRssFeed } from "@/utils/rss";

const posts = await fetchRssFeed("https://www.artformatics.com/api/boards/j-edit-1q6rb/rss");
const cleanedPosts = posts.map(post => {
  const cleanContent = post.content ? post.content.replace(/<img[^>]*>/gi, '') : (post.description || '');
  return {
    ...post,
    content: cleanContent
  };
});
---

<Layout title="J-Edit">
  <Container>
    <Sectionhead>
      <Fragment slot="title">J-Edit Community</Fragment>
      <Fragment slot="desc">Chronicles of community feed integrations, 3D systems, and drops parsed from Artformatics.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-8 mt-16">
      {cleanedPosts.length === 0 ? (
        <p class="text-center text-slate-500 py-12 col-span-3">No community editorial posts found.</p>
      ) : (
        cleanedPosts.map((post) => (
          <article class="border border-slate-200 rounded-2xl overflow-hidden hover:shadow-md transition-all duration-300 group flex flex-col h-full bg-white">
            {post.images && post.images.length > 0 && (
              <div class="product-image-container">
                <div class="relative overflow-hidden aspect-[4/5] bg-slate-50 flex items-center justify-center border-b border-slate-100">
                  <img
                    src={post.images[0]}
                    alt={post.title}
                    class="main-product-image w-full h-full object-contain group-hover:scale-102 transition-transform duration-500"
                  />
                </div>
                
                {post.images.length > 1 && (
                  <div class="flex gap-1.5 flex-wrap px-6 pt-3 justify-start z-10">
                    {post.images.map((img, idx) => (
                      <button
                        type="button"
                        class={`thumbnail-btn w-9 h-11 rounded overflow-hidden border-2 cursor-pointer transition-all duration-200 ${
                          idx === 0 ? 'border-slate-800 scale-105' : 'border-transparent opacity-70 hover:opacity-100'
                        }`}
                        data-image-src={img}
                      >
                        <img src={img} class="w-full h-full object-cover" />
                      </button>
                    ))}
                  </div>
                )}
              </div>
            )}
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <div class="text-xs text-slate-400 font-mono mb-2">
                  {post.pubDate ? new Date(post.pubDate).toLocaleDateString('en-US', { dateStyle: 'medium' }) : 'Editorial'}
                </div>
                <h3 class="text-lg font-bold text-gray-800 group-hover:text-indigo-650 transition-colors mb-3 leading-snug">
                  {post.title}
                </h3>
                <div class="text-sm text-slate-650 leading-relaxed mb-6 line-clamp-3" set:html={post.content}>
                </div>
              </div>
              <div class="border-t border-slate-100 pt-4 flex items-center justify-between text-xs font-semibold text-indigo-600 group-hover:text-indigo-500 transition-colors">
                <span>View Discussion</span>
                <span class="transform group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </div>
          </article>
        ))
      )}
    </div>
  </Container>
</Layout>

<script>
  // Image switcher handling
  document.querySelectorAll('.product-image-container').forEach(container => {
    const mainImg = container.querySelector('.main-product-image');
    const thumbBtns = container.querySelectorAll('.thumbnail-btn');
    
    thumbBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const targetSrc = btn.getAttribute('data-image-src');
        if (mainImg && targetSrc) {
          mainImg.setAttribute('src', targetSrc);
        }
        
        // Update active class styles
        thumbBtns.forEach(b => {
          b.classList.remove('border-slate-800', 'scale-105');
          b.classList.add('border-transparent', 'opacity-70');
        });
        btn.classList.add('border-slate-800', 'scale-105');
        btn.classList.remove('border-transparent', 'opacity-70');
      });
    });
  });
</script>
