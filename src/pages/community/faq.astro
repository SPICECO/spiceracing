---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import { fetchRssFeed } from "@/utils/rss";

const faqs = await fetchRssFeed("https://www.artformatics.com/api/boards/faq-dt3d9/rss");
---

<Layout title="FAQ">
  <Container>
    <Sectionhead>
      <Fragment slot="title">FAQ</Fragment>
      <Fragment slot="desc">Frequently Asked Questions, synced dynamically from Artformatics.</Fragment>
    </Sectionhead>

    <div class="max-w-3xl mx-auto mt-16 space-y-4">
      {faqs.length === 0 ? (
        <p class="text-center text-slate-500 py-12">No FAQ items found.</p>
      ) : (
        faqs.map((faq) => (
          <details class="group border border-slate-200 rounded-xl overflow-hidden transition-all duration-300">
            <summary class="flex justify-between items-center p-6 cursor-pointer select-none hover:bg-slate-50 transition-colors">
              <h3 class="text-base font-bold text-gray-800 transition-colors">{faq.title}</h3>
              <span class="relative w-5 h-5 shrink-0 ml-4">
                <span class="absolute top-1/2 left-0 w-5 h-0.5 bg-slate-400 group-open:rotate-90 transition-transform duration-300 -translate-y-1/2"></span>
                <span class="absolute top-0 left-1/2 w-0.5 h-5 bg-slate-400 group-open:rotate-90 transition-transform duration-300 -translate-x-1/2"></span>
              </span>
            </summary>
            <div class="p-6 pt-0 border-t border-slate-100 text-slate-600 text-sm leading-relaxed" set:html={faq.content}>
            </div>
          </details>
        ))
      )}
    </div>
  </Container>
</Layout>
