---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import { fetchRssFeed } from "@/utils/rss";

const aboutItems = await fetchRssFeed("https://www.artformatics.com/api/boards/about-vz47g/rss");
---

<Layout title="About">
  <Container>
    <Sectionhead>
      <Fragment slot="title">About SpiceCo</Fragment>
      <Fragment slot="desc">Decentralized branding, physical apparel drops, and digital WebGL artboards.</Fragment>
    </Sectionhead>

    <div class="max-w-4xl mx-auto mt-16 space-y-12">
      {aboutItems.length === 0 ? (
        <p class="text-center text-slate-500 py-12">About information is loading...</p>
      ) : (
        aboutItems.map((item, index) => (
          <div class={`grid md:grid-cols-2 gap-8 items-center ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
            <div class={index % 2 !== 0 ? 'md:order-last' : ''}>
              <h2 class="text-2xl font-bold text-gray-800 mb-4">{item.title}</h2>
              <div class="text-slate-600 leading-relaxed text-sm" set:html={item.content}></div>
            </div>
            
            {item.image && (
              <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white aspect-[4/3] flex items-center justify-center">
                <img src={item.image} alt={item.title} class="w-full h-full object-cover" />
              </div>
            )}
            {!item.image && (
              <div class="border border-slate-200 rounded-2xl p-8 bg-slate-50 relative overflow-hidden shadow-sm">
                <h3 class="text-xs font-mono text-slate-400 uppercase tracking-widest mb-4">Board Feed Reference</h3>
                <p class="text-xs text-slate-500 font-mono italic">
                  Item published on {item.pubDate ? new Date(item.pubDate).toLocaleDateString() : 'N/A'}
                </p>
              </div>
            )}
          </div>
        ))
      )}
    </div>
  </Container>
</Layout>
